<ListScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.15, 0.15, 0.15, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # 상단 메뉴바
        BoxLayout:
            size_hint_y: None
            height: '60dp'
            padding: '5dp'
            spacing: '5dp'
            canvas.before:
                Color:
                    rgba: 0.2, 0.2, 0.2, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: '설정'
                size_hint_x: 0.2
                on_release: app.open_smb_settings()
            Button:
                text: '엑셀 선택'
                on_release: app.select_source('excel')
            Button:
                text: 'PDF 폴더'
                on_release: app.select_source('pdf')
            Button:
                text: '저장'
                background_color: 0.2, 0.7, 0.3, 1
                size_hint_x: 0.2
                on_release: app.save_to_excel()

        # 머릿글 (정렬 기능 포함)
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            padding: [2, 0]
            canvas.before:
                Color:
                    rgba: 0.3, 0.3, 0.3, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Button:
                text: 'No' + app.sort_indicator_no
                size_hint_x: 0.1
                bold: True
                background_normal: ''
                background_color: 0.3, 0.3, 0.3, 1
                on_release: app.sort_by('no')
            Button:
                text: '품목코드' + app.sort_indicator_code
                size_hint_x: 0.3
                bold: True
                background_normal: ''
                background_color: 0.3, 0.3, 0.3, 1
                on_release: app.sort_by('item_code')
            Button:
                text: '수량' + app.sort_indicator_qty
                size_hint_x: 0.15
                bold: True
                background_normal: ''
                background_color: 0.3, 0.3, 0.3, 1
                on_release: app.sort_by('quantity')
            Button:
                text: '완료' + app.sort_indicator_comp
                size_hint_x: 0.15
                bold: True
                background_normal: ''
                background_color: 0.3, 0.3, 0.3, 1
                on_release: app.sort_by('complete')
            Button:
                text: '부족' + app.sort_indicator_short
                size_hint_x: 0.15
                bold: True
                background_normal: ''
                background_color: 0.3, 0.3, 0.3, 1
                on_release: app.sort_by('shortage')
            Button:
                text: '재작업' + app.sort_indicator_rew
                size_hint_x: 0.15
                bold: True
                background_normal: ''
                background_color: 0.3, 0.3, 0.3, 1
                on_release: app.sort_by('rework')

        # 데이터 리스트
        CheckSheetRV:
            id: rv
            viewclass: 'RowWidget'
            RecycleBoxLayout:
                default_size: None, dp(56)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: '1dp'

<ViewerScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Rectangle:
                pos: self.pos
                size: self.size
        padding: dp(10)
        
        # 상단바
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            spacing: dp(10)
            Label:
                id: viewer_title
                text: ""
                font_size: '20sp'
                bold: True
            Button:
                text: 'X 닫기'
                size_hint_x: None
                width: dp(100)
                on_release: app.close_viewer()

        # PDF 이미지 (스와이프)
        Image:
            id: pdf_img
            source: ""
            allow_stretch: True
            keep_ratio: True
            on_touch_down: app.on_viewer_touch_down(args[1])
            on_touch_up: app.on_viewer_touch_up(args[1])

        # 하단 버튼
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)
            padding: [0, dp(10)]
            
            Button:
                id: btn_comp
                text: '완료'
                on_release: app.update_item_status(viewer_title.text, app.root.get_screen('list').ids.rv.data[app.current_view_idx]['no'], 'complete')
            Button:
                id: btn_short
                text: '부족'
                on_release: app.update_item_status(viewer_title.text, app.root.get_screen('list').ids.rv.data[app.current_view_idx]['no'], 'shortage')
            Button:
                id: btn_rew
                text: '재작업'
                on_release: app.update_item_status(viewer_title.text, app.root.get_screen('list').ids.rv.data[app.current_view_idx]['no'], 'rework')

<RowWidget>:
    orientation: 'horizontal'
    padding: [5, 2]
    canvas.before:
        Color:
            rgba: 0.25, 0.25, 0.25, 1
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: root.no
        size_hint_x: 0.1
    
    Button:
        text: root.item_code
        size_hint_x: 0.3
        background_normal: ''
        background_color: 0.2, 0.4, 0.6, 1
        on_release: root.open_pdf()
        shorten: True
        shorten_from: 'right'

    Label:
        text: root.quantity
        size_hint_x: 0.15

    Button:
        text: 'V' if root.complete else ''
        size_hint_x: 0.15
        font_size: '20sp'
        background_normal: ''
        background_color: (0, 1, 0, 0.5) if root.complete else (0.4, 0.4, 0.4, 1)
        on_release: root.on_checkbox_active('complete')

    Button:
        text: 'V' if root.shortage else ''
        size_hint_x: 0.15
        font_size: '20sp'
        background_normal: ''
        background_color: (1, 1, 0, 0.5) if root.shortage else (0.4, 0.4, 0.4, 1)
        on_release: root.on_checkbox_active('shortage')

    Button:
        text: 'V' if root.rework else ''
        size_hint_x: 0.15
        font_size: '20sp'
        background_normal: ''
        background_color: (1, 0, 0, 0.5) if root.rework else (0.4, 0.4, 0.4, 1)
        on_release: root.on_checkbox_active('rework')
